# 复制为 .env 并填写（.env 已被 .gitignore 忽略，不会提交）
# 数据库（docker-compose 默认）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ragkb
DB_USERNAME=ragkb
DB_PASSWORD=ragkb

# Embedding：留空则自动使用本地 hash 兜底（无需任何 key 即可跑 M1）
EMBEDDING_PROVIDER=auto
EMBEDDING_API_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_API_MODEL=text-embedding-3-small

# JWT（生产务必修改）
JWT_SECRET=change-me-in-production-please-1234567890
