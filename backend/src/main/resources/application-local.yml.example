# ============================================================
# 本地密钥配置模板（仅本地使用，不会进版本库）
# ============================================================
# 用法：
#   1) 复制本文件为 application-local.yml（已纳入 .gitignore，绝不会被提交）
#        cp application-local.yml.example application-local.yml
#   2) 把下面 sk-xxx 换成你自己的 DeepSeek / OpenAI 兼容 key
#   3) 启动后端时激活 local profile（见下）
#
# 启动命令（任选其一）：
#   PowerShell:  mvn spring-boot:run -Dspring-boot.run.profiles=local
#   IDEA:        Run/Debug Configurations → Active profiles 填 local
#   jar:         java -jar target/xxx.jar --spring.profiles.active=local
#
# 不配置本文件也能跑（自动降级为原文片段拼接，非 LLM 生成）。
# 配置后访问 GET /api/chat/llm-status 可自检 available=true 即代表已接入大模型。
# ============================================================

llm:
  api:
    # 你的 LLM key（DeepSeek / OpenAI 兼容均可）
    key: sk-这里替换为你的key
    # 可选：自定义模型与 base-url（默认 deepseek-chat / https://api.deepseek.com/v1）
    # base-url: https://api.deepseek.com/v1
    # model: deepseek-chat
